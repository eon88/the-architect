# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=architect_user
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=architect_db

# Computed automatically by docker-compose – no need to change unless the db
# service name or port differs.
DATABASE_URL=postgresql://architect_user:your_strong_password_here@db:5432/architect_db

# ── Google Gemini ─────────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here
